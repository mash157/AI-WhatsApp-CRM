# Backend Configuration

# MongoDB Connection
# For Local MongoDB (Docker or local installation):
MONGO_URI=mongodb://whatsapp_admin:whatsapp_secure_password_123@localhost:27017/whatsappdb?authSource=admin

# For MongoDB Atlas (Cloud) - Replace <password> and <cluster> with your values:
# MONGO_URI=mongodb+srv://whatsapp_admin:<password>@<cluster>.mongodb.net/whatsappdb?retryWrites=true&w=majority

# MongoDB Database Name
MONGODB_DB_NAME=whatsappdb

# JWT Settings
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345
DEVELOPER_CODE=SUPER_SECRET_DEVELOPER_CODE

# AI Provider (Groq recommended)
GROQ_API_KEY=your_groq_api_key_starts_with_gsk_
GROQ_MODEL=llama-3.1-8b-instant

# Backward compatibility (optional)
# GEMINI_API_KEY=your_legacy_gemini_key
# OPENAI_API_KEY=your_legacy_openai_key

# Email Service (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Payment Services
## Razorpay (India)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

## Stripe (Global)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLIC_KEY=your_stripe_public_key

# WhatsApp Integration
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_ID=your_whatsapp_phone_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_cloud_api_access_token
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# Firebase (Notifications)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id

# Twilio (SMS Fallback)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Application Settings
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Optional: Logging
LOG_LEVEL=info
